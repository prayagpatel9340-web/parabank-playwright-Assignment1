{
  "name": "parabank-playwright",
  "version": "1.0.0",
  "description": "Playwright E2E test suite for ParaBank – home assignment",
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test tests/banking-flow.spec.ts",
    "test:negative": "playwright test tests/negative-scenarios.spec.ts",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "install:browsers": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
